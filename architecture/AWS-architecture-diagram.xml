<mxfile host="app.diagrams.net">
  <diagram name="TravelMemory AWS VPC Architecture">
    <mxGraphModel grid="1" gridSize="10" page="1" pageWidth="1600" pageHeight="900">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- User -->
        <mxCell id="user" value="User (Browser HTTPS)" style="ellipse;html=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="20" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- Cloudflare -->
        <mxCell id="cloudflare" value="Cloudflare\nDNS + SSL" style="rounded=1;html=1;fillColor=#e6f2ff;" vertex="1" parent="1">
          <mxGeometry x="700" y="100" width="220" height="70" as="geometry"/>
        </mxCell>

        <!-- VPC -->
        <mxCell id="vpc" value="AWS VPC" style="rounded=1;html=1;fillColor=#f5f5f5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="200" width="1400" height="620" as="geometry"/>
        </mxCell>

        <!-- Internet Gateway -->
        <mxCell id="igw" value="Internet Gateway" style="rounded=1;html=1;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="700" y="230" width="220" height="60" as="geometry"/>
        </mxCell>

        <!-- Public Subnet AZ-1 -->
        <mxCell id="subnet1" value="Public Subnet (AZ-1)" style="rounded=1;html=1;fillColor=#ffffff;strokeDasharray=3 3;" vertex="1" parent="1">
          <mxGeometry x="150" y="320" width="550" height="420" as="geometry"/>
        </mxCell>

        <!-- Public Subnet AZ-2 -->
        <mxCell id="subnet2" value="Public Subnet (AZ-2)" style="rounded=1;html=1;fillColor=#ffffff;strokeDasharray=3 3;" vertex="1" parent="1">
          <mxGeometry x="750" y="320" width="700" height="420" as="geometry"/>
        </mxCell>

        <!-- Frontend EC2 -->
        <mxCell id="frontend" value="EC2\nTM-Master-Server\nReact + Nginx" style="rounded=1;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="200" y="380" width="260" height="120" as="geometry"/>
        </mxCell>

        <!-- ALB -->
        <mxCell id="alb" value="Application Load Balancer" style="rounded=1;html=1;fillColor=#ffe6cc;" vertex="1" parent="1">
          <mxGeometry x="870" y="380" width="300" height="120" as="geometry"/>
        </mxCell>

        <!-- Backend 01 -->
        <mxCell id="backend1" value="EC2\ntravelMemory-backend-01\nNode.js + PM2" style="rounded=1;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="800" y="560" width="300" height="120" as="geometry"/>
        </mxCell>

        <!-- Backend 02 -->
        <mxCell id="backend2" value="EC2\ntravelMemory-backend-02\nNode.js + PM2" style="rounded=1;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="1150" y="560" width="300" height="120" as="geometry"/>
        </mxCell>

        <!-- MongoDB Atlas -->
        <mxCell id="mongo" value="MongoDB Atlas\n(External Managed DB)" style="shape=cylinder;html=1;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="650" y="770" width="300" height="100" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
